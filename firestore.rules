rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwnDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validRole(role) {
      return role in ['student', 'driver', 'admin'];
    }

    function validProfile(data) {
      return data.email is string
        && data.name is string
        && validRole(data.role)
        && validLocation(data);
    }

    function validLocation(data) {
      return data.location == null
        || (
          data.location.latitude is number
          && data.location.longitude is number
        );
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function userExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    function isDriver(userId) {
      return userExists(userId) && userDoc(userId).data.role == 'driver';
    }

    function isAdmin(userId) {
      return userExists(userId) && userDoc(userId).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if (
        isOwnDoc(userId)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == 'student'
        && validProfile(request.resource.data)
      ) || (
        signedIn()
        && isAdmin(request.auth.uid)
        && request.resource.data.role == 'driver'
        && validProfile(request.resource.data)
      );

      allow update: if isOwnDoc(userId)
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && validRole(request.resource.data.role)
        && validLocation(request.resource.data);

      allow delete: if isOwnDoc(userId);
    }

    match /locations/{userId} {
      allow read: if signedIn();

      allow create, update: if isOwnDoc(userId)
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number;

      allow delete: if isOwnDoc(userId);
    }

    match /routes/{routeId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && (
          (
            isDriver(request.auth.uid)
            && request.resource.data.driverId == request.auth.uid
          )
          || isAdmin(request.auth.uid)
        );

      allow update: if signedIn()
        && (
          (
            isDriver(request.auth.uid)
            && (
              resource.data.driverId == request.auth.uid
              || request.resource.data.driverId == request.auth.uid
            )
          )
          || isAdmin(request.auth.uid)
        );

      allow delete: if signedIn() && isAdmin(request.auth.uid);
    }
  }
}
