rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwnDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validRole(role) {
      return role in ['student', 'driver', 'admin'];
    }

    function validProfile(data) {
      return data.keys().hasOnly(['email', 'name', 'role'])
        && data.email is string
        && data.name is string
        && validRole(data.role);
    }

    function userExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    function isAdmin(userId) {
      return userExists(userId)
        && get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    function isStudent(userId) {
      return userExists(userId)
        && get(/databases/$(database)/documents/users/$(userId)).data.role == 'student';
    }

    function isDriver(userId) {
      return userExists(userId)
        && get(/databases/$(database)/documents/users/$(userId)).data.role == 'driver';
    }

    function validLocation(data) {
      return data.keys().hasOnly([
          'latitude',
          'longitude',
          'accuracyMeters',
          'speedKmh',
          'isFull',
          'role',
          'updatedAt'
        ])
        && data.keys().hasAll(['latitude', 'longitude', 'role', 'updatedAt'])
        && data.latitude is number
        && data.longitude is number
        && validRole(data.role)
        && data.updatedAt is timestamp
        && (!data.keys().hasAny(['accuracyMeters']) || data.accuracyMeters is number)
        && (!data.keys().hasAny(['speedKmh']) || data.speedKmh is number)
        && (!data.keys().hasAny(['isFull']) || (data.role == 'driver' && data.isFull is bool));
    }

    function validSchedule(data) {
      return data.keys().hasOnly([
          'ejeepName',
          'route',
          'dayRange',
          'startTime',
          'endTime',
          'day',
          'departureTime',
          'isActive',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && data.keys().hasAll(['ejeepName', 'route', 'isActive'])
        && (
          data.keys().hasAll(['dayRange', 'startTime', 'endTime'])
          || data.keys().hasAll(['day', 'departureTime'])
        )
        && data.ejeepName is string
        && data.route is string
        && data.isActive is bool
        && (!data.keys().hasAny(['dayRange']) || data.dayRange is string)
        && (!data.keys().hasAny(['startTime']) || data.startTime is string)
        && (!data.keys().hasAny(['endTime']) || data.endTime is string)
        && (!data.keys().hasAny(['day']) || data.day is string)
        && (!data.keys().hasAny(['departureTime']) || data.departureTime is string)
        && (!data.keys().hasAny(['notes']) || data.notes is string)
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp);
    }

    match /users/{userId} {
      allow read: if signedIn()
        && (
          isOwnDoc(userId)
          || isAdmin(request.auth.uid)
          || (
            isStudent(request.auth.uid)
            && resource.data.role == 'driver'
          )
        );

      allow create: if (
        isOwnDoc(userId)
        && request.resource.data.role == 'student'
        && request.resource.data.email == request.auth.token.email
        && validProfile(request.resource.data)
      ) || (
        signedIn()
        && isAdmin(request.auth.uid)
        && request.resource.data.role == 'driver'
        && validProfile(request.resource.data)
      );

      allow update: if isOwnDoc(userId)
        && request.resource.data.keys().hasOnly(['email', 'name', 'role'])
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && validRole(request.resource.data.role);

      allow delete: if isOwnDoc(userId);
    }

    match /locations/{userId} {
      allow read: if signedIn()
        && (
          isOwnDoc(userId)
          || isAdmin(request.auth.uid)
          || (
            isStudent(request.auth.uid)
            && resource.data.role == 'driver'
          )
          || (
            isDriver(request.auth.uid)
            && resource.data.role == 'student'
          )
        );

      allow create, update: if isOwnDoc(userId)
        && userExists(userId)
        && validLocation(request.resource.data)
        && request.resource.data.role == get(/databases/$(database)/documents/users/$(userId)).data.role;

      allow delete: if isOwnDoc(userId);
    }

    match /schedules/{scheduleId} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && isAdmin(request.auth.uid)
        && validSchedule(request.resource.data);

      allow delete: if signedIn() && isAdmin(request.auth.uid);
    }
  }
}
